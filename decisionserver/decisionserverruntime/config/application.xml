<server>
	<!-- Decision Server Runtime -->
	<application type="war" context-root="${ODM_CONTEXT_ROOT}/DecisionService" autoStart="true" id="DecisionService" name="DecisionService" location="${server.config.dir}/apps/DecisionService.war">
		<application-bnd>
			<security-role name="resExecutors">
				<group name="resExecutors" />
			</security-role>
		</application-bnd>
	<classloader delegation="parentLast">
    		<privateLibrary>
      			<folder dir="/config/pluginconfig" id="plugin-resources"  />
    		</privateLibrary>
                <privateLibrary>
                        <folder dir="/config/extension" id="extension-resources"  />
                </privateLibrary>
		<privateLibrary>
                        <folder dir="/config/download" id="download-resources"/>
                </privateLibrary>
                <privateLibrary>
                        <fileset dir="/config/download" includes="*.jar" scanInterval="5s" id="download-jars"/>
                </privateLibrary>
  	</classloader>
	</application>

</server>
