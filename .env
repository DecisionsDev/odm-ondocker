# ODM product version
ODMVERSION=9.6.0.0

# CP4BA product version
CP4BAVERSION=26.0.0


# ODM database schema version
ODMDBVERSION=9.0.next

# Directory name of the odm-ondocker checkout
ODMDOCKERDIR=odm-ondocker

# Image use to do multistage build
FROMDOCKERBUILD=maven:3.9.9-ibm-semeru-21-jammy

# Repository name of the images
REPOSITORY=ibmcom

# Image prefix
PREFIXIMAGE=odm

# Liberty Version
FROMLIBERTY=icr.io/appcafe/websphere-liberty:25.0.0.12-kernel-java21-openj9-ubi-minimal

PACKAGELIST="servlet-6.0 pages-3.1 jdbc-4.3 appSecurity-5.0 concurrent-3.0 jndi-1.0 audit-2.0 logstashcollector-1.0 mpMetrics-5.1 openidconnectclient-1.0 collectiveMember-1.0 sessionCache-1.0 ldapRegistry-3.0 monitor-1.0 transportSecurity-1.0"


# Postgres Version
FROMPOSTGRES=postgres:16
POSTGRESUID=999
