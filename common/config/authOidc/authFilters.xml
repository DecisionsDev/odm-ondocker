<?xml version="1.0" encoding="UTF-8"?>
<server>
    <authFilter id="browserAuthFilter">
		<requestHeader id="allowBasicAuth" matchType="notContain" name="Authorization" />
    </authFilter>

	<authFilter id="apiAuthFilter">
		<requestHeader id="allowBasicAuth" matchType="contains" name="Authorization" />
    </authFilter>
</server>
